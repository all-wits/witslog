{
  "name": "@all-wits/witslog",
  "version": "0.6.4",
  "description": "Framework-agnostic Node.js SDK for witslog structured error logging",
  "license": "Apache-2.0",
  "author": "witslog team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/all-wits/witslog.git",
    "directory": "bindings/node"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./fetch": {
      "types": "./fetch.d.ts",
      "default": "./fetch.js"
    },
    "./browser": {
      "types": "./browser.d.ts",
      "default": "./browser.js"
    },
    "./frameworks/*": {
      "types": "./frameworks/*.d.ts",
      "default": "./frameworks/*.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "witslog": "bin/witslog.js"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "fetch.js",
    "fetch.d.ts",
    "browser.js",
    "browser.d.ts",
    "CHANGELOG.md",
    "lib/",
    "frameworks/",
    "bin/",
    "_libs/",
    "_bin/"
  ],
  "scripts": {
    "test": "node --test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "logging",
    "errors",
    "sqlite",
    "observability"
  ],
  "dependencies": {
    "koffi": "^2.9.0"
  },
  "devDependencies": {
    "webpack": "^5.94.0"
  }
}
