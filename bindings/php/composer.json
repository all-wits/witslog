{
  "name": "witslog/witslog",
  "description": "Framework-agnostic PHP/Laravel SDK for witslog structured error logging",
  "type": "library",
  "license": "Apache-2.0",
  "require": {
    "php": ">=8.1",
    "ext-ffi": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10 || ^11"
  },
  "autoload": {
    "psr-4": {
      "Witslog\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Witslog\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Witslog\\Laravel\\WitslogServiceProvider"
      ]
    }
  }
}
